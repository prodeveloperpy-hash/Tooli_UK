# Copy to `.env` or `.env.local` (gitignored). Restart `npm run dev` after changes.
# Only variables prefixed with VITE_ are exposed to the browser (Vite rule).
#
# Local Django:
# VITE_API_URL=http://localhost:8000
#
# Production (your Cloud Run or other backend URL — no trailing slash):
# VITE_API_URL=https://your-backend-xxxx.us-central1.run.app

VITE_API_URL=http://localhost:8000
